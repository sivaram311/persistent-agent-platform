# Local configuration template
# Copy to application-local.yml and adjust values
# Author: SIVARAMAN R <sivaram311@gmail.com>

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/agent_platform
    username: agent_user
    password: YOUR_PASSWORD_HERE

agent:
  workspace-root: E:/MyWorkspace/persistent-agent-platform
  security:
    enabled: false
    username: admin
    password: CHANGE_ME
  cli:
    cursor-agent-path: C:/Users/Administrator/AppData/Local/cursor-agent/cursor-agent.cmd
    antigravity-path: C:/Users/Administrator/AppData/Local/agy/bin/agy.exe
  langgraph:
    enabled: true
    service-url: http://localhost:8090
  dify:
    enabled: false
    base-url: http://localhost:3000
    api-key:

logging:
  level:
    com.sivaraman.agentplatform: DEBUG
